# Streamlit Cloud Secrets Template
# In Streamlit Cloud dashboard, go to App Settings → Secrets and paste the following block
# (fill in your real values, do NOT commit this file to GitHub)

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_KEY = "your-anon-public-key"
AWS_ACCESS_KEY_ID = "your-s3-key-id"
AWS_SECRET_ACCESS_KEY = "your-s3-secret"
BRAINTREE_MERCHANT_ID = "your-merchant-id"
BRAINTREE_PUBLIC_KEY = "your-public-key"
BRAINTREE_PRIVATE_KEY = "your-private-key"
SHIPPO_API_KEY = "shippo_test_XXXX"
